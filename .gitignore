*.o
*.rlib
*.so
*.dll
*.dylib

# CPAC output files
*.cpac
*.cpar
*.cpac-enc
*.cpac-pqe
*.cpac-sig
*.cpac-pub
*.cpac-sec

# Criterion benchmark output
target/criterion/

# PGO profiles
*.profraw
*.profdata
pgo-data/

# Python venv (managed by shell.ps1/shell.sh)
__pycache__/
*.pyc

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
