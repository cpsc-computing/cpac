# Build artifacts
/target/
fuzz/target/

# Rust backup files
**/*.rs.bk

# Dependency lock (library — consumers pin their own)
Cargo.lock

# Working directories (all temporary/generated files must go here)
.work/

# Benchmark files (should be in .work/benchmarks/)
bench-corpus/
bench-results*.csv
bench-results*.md
LINKEDIN_BENCHMARK_REPORT.md
OPTIMIZATION_RECOMMENDATIONS.md

# Build artifacts that shouldn't escape target/
*.o
*.rlib
*.so
*.dll
*.dylib

# CPAC output files
*.cpac
*.cpar
*.cpac-enc
*.cpac-pqe
*.cpac-sig
*.cpac-pub
*.cpac-sec

# Criterion benchmark output
target/criterion/

# PGO profiles
*.profraw
*.profdata
pgo-data/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
